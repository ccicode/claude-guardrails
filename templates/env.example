# =============================================================================
# .env.example — Plantilla de variables de entorno
# =============================================================================
# Uso:
#   1. Copiar este archivo a `.env`:
#        Git Bash / Linux:  cp .env.example .env
#        PowerShell:        Copy-Item .env.example .env
#   2. Reemplazar los valores de ejemplo por los reales.
#   3. No incluir `.env` en el repositorio. `.gitignore` ya lo excluye, pero
#      evitar `--no-verify` en los commits para no saltarse esa barrera.
#   4. Al renombrar una variable, comunicar el cambio al resto del equipo.
#      Este archivo es la fuente de verdad sobre qué variables existen.
# =============================================================================


# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# DATABASE_URL=mysql://user:password@localhost:3306/mydb
# DATABASE_URL=sqlite:///./app.db

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20


# -----------------------------------------------------------------------------
# APIs externas (modelos de IA, servicios de terceros)
# -----------------------------------------------------------------------------
# Claves privadas con costo asociado. Una filtración permite consumo en la
# cuenta original hasta que se roten manualmente en el panel del proveedor.

OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
SENDGRID_API_KEY=your-sendgrid-api-key-here
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here


# -----------------------------------------------------------------------------
# Autenticación y seguridad
# -----------------------------------------------------------------------------
# `SECRET_KEY` firma sesiones, cookies y tokens. Generar una clave distinta
# en producción:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

SECRET_KEY=change-me-generate-a-unique-value-for-production
JWT_SECRET=change-me-use-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret


# -----------------------------------------------------------------------------
# Configuración de la aplicación
# -----------------------------------------------------------------------------
APP_ENV=development
# APP_ENV=staging
# APP_ENV=production

DEBUG=true
LOG_LEVEL=info
# LOG_LEVEL=debug | info | warning | error

PORT=3000
HOST=0.0.0.0

APP_URL=http://localhost:3000
API_URL=http://localhost:8000

CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# -----------------------------------------------------------------------------
# Infraestructura (caché, storage, colas)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-aws-access-key-id
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_ENDPOINT_URL=https://s3.amazonaws.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@example.com


# -----------------------------------------------------------------------------
# Observabilidad (opcional)
# -----------------------------------------------------------------------------
SENTRY_DSN=your-sentry-dsn
LOGTAIL_TOKEN=your-logtail-token


# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
FEATURE_NEW_DASHBOARD=false
FEATURE_BETA_AI=false
MAINTENANCE_MODE=false
